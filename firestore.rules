rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isHostOfCharger(chargerId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/chargers/$(chargerId)).data.host_id == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update: if isSelf(userId);
      allow delete: if false;
    }

    match /wallets/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId) && request.resource.data.user_id == request.auth.uid;
      allow update: if isSelf(userId) && resource.data.user_id == request.auth.uid;
      allow delete: if false;

      match /transactions/{transactionId} {
        allow read: if isSelf(userId);
        allow create, update: if isSelf(userId);
        allow delete: if false;
      }
    }

    match /chargers/{chargerId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.host_id == request.auth.uid;
      allow update: if isSignedIn() && ('host_id' in resource.data && resource.data.host_id == request.auth.uid);
      allow delete: if false;

      match /packages/{packageId} {
        allow read: if true;
        allow create, update: if isHostOfCharger(chargerId);
        allow delete: if false;
      }
    }

    match /bookings/{bookingId} {
      allow read: if isSignedIn() &&
        (('user_id' in resource.data && resource.data.user_id == request.auth.uid) || 
         ('host_id' in resource.data && resource.data.host_id == request.auth.uid));

      allow create: if isSignedIn() &&
        request.resource.data.user_id == request.auth.uid;

      allow update: if isSignedIn() &&
        (('user_id' in resource.data && resource.data.user_id == request.auth.uid) || 
         ('host_id' in resource.data && resource.data.host_id == request.auth.uid));

      allow delete: if false;
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn() && ('user_id' in resource.data && resource.data.user_id == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn() && ('user_id' in resource.data && resource.data.user_id == request.auth.uid);
      allow delete: if false;
    }

    match /{path=**}/chargers/{chargerId} {
      allow read: if true;
    }

    match /{path=**}/bookings/{bookingId} {
      allow read: if isSignedIn() && 
        (('user_id' in resource.data && resource.data.user_id == request.auth.uid) || 
         ('host_id' in resource.data && resource.data.host_id == request.auth.uid));
    }

    match /{path=**}/sessions/{sessionId} {
      allow read: if isSignedIn() && ('user_id' in resource.data && resource.data.user_id == request.auth.uid);
    }
  }
}

